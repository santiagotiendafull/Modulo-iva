# Copiá este archivo a ".env" (en esta misma carpeta) y completá los valores reales.
# ".env" nunca se sube a git (está en .gitignore) — son datos sensibles.
#
# Sin estas dos variables, la app usa un archivo SQLite local (backend/data/modulo_iva.db) —
# perfecto para desarrollar en tu máquina. Con estas dos variables seteadas, usa Turso.

# Base de datos en Turso (turso.tech). La conseguís en el dashboard de tu base:
# "Database URL" — arranca con libsql://
TURSO_DATABASE_URL=

# El token de acceso de esa misma base (dashboard → tu base → "Create Token").
TURSO_AUTH_TOKEN=
